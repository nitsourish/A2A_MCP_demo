# Copy this file to .env and fill in your XWeather app credentials
# (https://www.xweather.com -> account dashboard -> your registered app).
# XWeather issues these as a PAIR - both are required on every request.
# Without them, the Weather Agent falls back to mock data automatically.
XWEATHER_CLIENT_ID=
XWEATHER_CLIENT_SECRET=

# Optional: LangSmith tracing (https://smith.langchain.com -> Settings -> API Keys).
# Without these, the demo runs identically, just without traces uploaded.
# LANGSMITH_TRACING=true is required even if LANGSMITH_API_KEY is set - the
# SDK does not infer "enabled" from the key's presence alone.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=a2a-demo
